# ============================================================================
# FastScore — environment variables
# ----------------------------------------------------------------------------
# This file is documentation only. None of these are loaded at runtime — they
# are read from Netlify's UI (Site settings → Environment variables) in
# production, and from your shell when running functions locally via the
# Netlify CLI.
#
# Copy this file to .env (gitignored) if you want to use netlify-cli locally.
# ============================================================================

# ---- REQUIRED -------------------------------------------------------------
# Neon Postgres pooled connection string. The schema lives in schema.sql.
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require

# Two long random hex strings (128 chars recommended). Must be different.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-128-char-hex
JWT_REFRESH_SECRET=replace-with-128-char-hex

# API-Football (api-football.com). Used by netlify/functions/_shared/football.js
# to fetch fixtures, scores, lineups, referees, injuries.
FOOTBALL_API_KEY=your-api-football-key

# OpenRouter (openrouter.ai). Backs the Claude analysis pipeline.
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Strong password gating the /admin panel and admin-only function triggers.
ADMIN_PASSWORD=pick-a-strong-password

# Whop (whop.com) — payment provider for the SHARP tier.
WHOP_WEBHOOK_SECRET=whop_xxx        # Whop dashboard → Developer → Webhooks → reveal secret
WHOP_CHECKOUT_URL=https://whop.com/checkout/your-product-id  # Whop product → copy checkout link

# ---- FRONTEND --------------------------------------------------------------
# Vite-prefixed variables are bundled into the client JS at build time.
# Safe to expose — these are public checkout URLs, not secrets.
VITE_WHOP_CHECKOUT_URL=https://whop.com/checkout/your-product-id  # exposed to client, can match WHOP_CHECKOUT_URL

# ---- AUTO-SET BY NETLIFY --------------------------------------------------
# URL is filled by Netlify with the site's primary URL. Used by the
# OpenRouter HTTP-Referer header and a couple of cross-function helpers.
# You don't need to set this manually in production.
# URL=https://your-site.netlify.app

# DEPLOY_URL is also auto-injected by Netlify, set to the unique URL of
# the current deploy (per-PR previews, branch deploys, etc). Several
# functions fall back to it when URL is missing. Don't set manually.
# DEPLOY_URL=https://deploy-preview-123--your-site.netlify.app

# NODE_ENV is also set by Netlify in production. We only check it to decide
# whether to mark auth cookies Secure. Leave it alone in Netlify UI.
# NODE_ENV=production

# ---- OPTIONAL -------------------------------------------------------------
# Resend (resend.com) for the daily-digest email. Skip if you're not running
# notifications yet — the email function gracefully no-ops when unset.
RESEND_API_KEY=
RESEND_FROM=FastScore <hi@example.com>

# OpenWeatherMap free tier — enables weather-aware predictions when wired in.
OPENWEATHER_API_KEY=

# the-odds-api.com. Without it, the dashboard auto-odds disappear and users
# fall back to manual odds entry on each match card. The odds-monitor agent
# and sharp-move detection require this key.
ODDS_API_KEY=

# Override the default API-Football season. Defaults to the value baked into
# football.js (currently 2024 — set during the free-tier-cap rollout). Set
# this on Netlify if you ever need to point at a different season.
FOOTBALL_DEFAULT_SEASON=
