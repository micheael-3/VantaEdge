generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Tier {
  FREE
  SCOUT
  ANALYST
  EDGE
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  tier            Tier     @default(FREE)
  revenuecatId    String?
  refreshToken    String?
  dailyRefreshes  Int      @default(0)
  lastRefreshDate String?
  createdAt       DateTime @default(now())
  predictions     Prediction[]
  history         PredictionHistory[]
}

model Prediction {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  league           String
  fixtureId        Int
  homeTeam         String
  awayTeam         String
  kickoff          DateTime
  overLine         Float
  overConfidence   Int
  overHit          Boolean?
  btts             String
  bttsConfidence   Int
  bttsHit          Boolean?
  evEdgeOver       Float?
  evEdgeBtts       Float?
  kellyOver        Float?
  kellyBtts        Float?
  createdAt        DateTime @default(now())
}

model PredictionHistory {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  date             String
  totalPredictions Int
  hits             Int
  accuracy         Float
  league           String
}
